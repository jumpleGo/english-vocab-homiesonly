  "grammar_rules": [
    {
      "rule": "1st Conditional",
      "structure": "If + Present Simple, will + V",
      "use": "Реальное будущее",
      "example": "If I go, will you come with me?"
    },
    {
      "rule": "2nd Conditional",
      "structure": "If + Past Simple, would + V",
      "use": "Нереальное настоящее / гипотеза",
      "example": "What would you be doing if I wasn't here?"
    },
    {
      "rule": "3rd Conditional",
      "structure": "If + Past Perfect, would have + V3",
      "use": "Нереальное прошлое / сожаление",
      "example": "If you had told me, I'd never have believed you."
    },
    {
      "rule": "Yes/No Question Intonation",
      "structure": "Voice goes UP ↗ at end",
      "use": "Вопрос звучит вежливо",
      "example": "Do you mind? ↗ / Are you sure? ↗"
    },
    {
      "rule": "-ish suffix",
      "structure": "number/adj + -ish",
      "use": "Приблизительность",
      "example": "five-ish, tired-ish, TikTok-ish"
    },
    {
      "rule": "Parallelism",
      "structure": "Same grammatical form in list",
      "use": "Академическое и деловое письмо",
