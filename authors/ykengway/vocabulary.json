  "grammar_rules": [
    {
      "rule": "used to vs would",
      "explanation": "used to = прошлые состояния/привычки (включая states). would = повторяющиеся действия (НЕ states!)",
      "example": "He used to have long hair. Every summer, we would go to the seaside."
    },
    {
      "rule": "used to / be used to / get used to",
      "explanation": "used to DO = делал раньше. be used to DOING = привычен сейчас. get used to DOING = процесс привыкания.",
      "example": "I used to smoke. I'm used to waking up early. I'm getting used to the new schedule."
    },
    {
      "rule": "Myth of perfect grammar",
      "explanation": "Ясность и уверенность важнее идеальной грамматики. Носители тоже 'нарушают' правила.",
      "example": "'Me and Sarah went...' instead of 'Sarah and I went...'"
    }
  ],
